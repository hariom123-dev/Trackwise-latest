# TrackWise Environment Variables Configuration
# Copy this file to .env.local and fill in the values for local development
# For Render deployment, add these variables in the Render dashboard under "Environment Variables"

# ==================== REQUIRED ====================

# Gemini AI API Key
# Get from: https://aistudio.google.com/app/apikey
# This is required for AI predictions and analysis features
GEMINI_API_KEY=

# Razorpay Payment Gateway Keys
# Get from: https://dashboard.razorpay.com/
# These are required for subscription payment processing
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ==================== OPTIONAL ====================

# Node Environment (development | production | staging)
# Default: development
NODE_ENV=development

# Server Port
# Default: 3000
# Render will automatically assign a PORT, so this is mainly for local development
PORT=3000

# Application URL
# Used for self-referential links, OAuth callbacks, and API endpoints
# For Render: https://your-app-name.onrender.com
# For Local: http://localhost:3000
APP_URL=http://localhost:3000

# ==================== SETUP INSTRUCTIONS ====================
# 
# 1. Get Gemini API Key:
#    - Go to https://aistudio.google.com/app/apikey
#    - Click "Get API Key"
#    - Copy and paste the key to GEMINI_API_KEY
#
# 2. Get Razorpay Keys:
#    - Go to https://dashboard.razorpay.com/
#    - Navigate to Settings > API Keys
#    - Copy Key ID and Key Secret
#
# 3. Local Development:
#    - Copy this file: cp .env.example .env.local
#    - Fill in your API keys in .env.local
#    - Run: npm run dev
#
# 4. Render Deployment:
#    - Go to Render Dashboard
#    - Navigate to your service > Environment
#    - Add these environment variables
#    - Set NODE_ENV=production
#    - Set APP_URL=https://your-app-name.onrender.com
#    - Click "Save Changes" and redeploy

